# Copy to .env and fill in before running `docker compose up -d --build`.
# See docs/SETUP.md for how to obtain the Google/VAPID values.

# Public URL of the frontend container (change to your NAS/host IP or domain, plus
# the published port below)
FRONTEND_URL=http://localhost:8080
FRONTEND_PORT=8080

# Comma-separated list of frontend origins allowed to call the API from a browser.
# Always include this app's own FRONTEND_URL. If Family-Dashboard runs on the SAME
# host (recommended, see docs/SETUP.md), also add its published address, e.g.
# http://localhost:3080. Leave empty to allow any origin (not recommended).
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3080

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Web Push (generate with: cd backend && npm run generate-vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
