# Copy to .env and fill in before running `docker compose up -d --build`.
# See docs/SETUP.md for how to obtain the Google/VAPID values.

# Public URL of the frontend container (change to your NAS IP/domain + published port)
FRONTEND_URL=http://localhost:8080
FRONTEND_PORT=8080

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Web Push (generate with: cd backend && npm run generate-vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
